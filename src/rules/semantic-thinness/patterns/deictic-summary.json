{
  "id": "deictic-summary",
  "class": "deictic-summary",
  "purpose": "Catch deictic summary pronouncements that point at a supposed lesson, truth, promise, or part without naming the concrete claim.",
  "matchMode": "contains",
  "maxTokens": 80,
  "templates": [
    "{deicticSubject} {linkingVerb} the {summaryNoun}.",
    "{deicticSubject} {linkingVerb} the {evaluativeAdjective} {summaryNoun}.",
    "{deicticSubject} {linkingVerb} the {summaryNoun} that {thinPredicate}.",
    "{deicticSubject} {linkingVerb} the {summaryNoun} {genericAudience} {reactionVerb}.",
    "{deicticSubject} {summaryVerb} the {summaryNoun}.",
    "{deicticSubject} {summaryVerb} the {evaluativeAdjective} {summaryNoun}.",
    "{deicticSubject} {meaningVerb} {summaryNoun}.",
    "{deicticSubject} {explanationVerb} {summaryNoun}.",
    "{deicticSubject} {explanationVerb} the {summaryNoun}.",
    "{deicticSubject} {meaningVerb} {abstractSubject} {linkingVerb} {weakJudgment}.",
    "{deicticSubject} {explanationVerb} why {abstractSubject} {abstractVerb}.",
    "{deicticSubject} {explanationVerb} how {abstractSubject} {abstractVerb}.",
    "{deicticSubject} means the {artifactNoun} has to {thinObligation}.",
    "{deicticSubject} means the {artifactNoun} has to contain {abstractObject} worth {abstractGerund}.",
    "{deicticSubject} {linkingVerb} the kind of {summaryNoun}.",
    "{deicticSubject} {linkingVerb} the type of {summaryNoun}.",
    "{deicticSubject} fits the {abstractSituation}.",
    "{deicticSubject} {changeVerb} the {changeObject}.",
    "{deicticSubject} {linkingVerb} where {abstractSubject} {abstractVerb}.",
    "{deicticSubject} {linkingVerb} how {abstractSubject} {abstractVerb}.",
    "{deicticSubject} {linkingVerb} why {abstractSubject} {importanceVerb}.",
    "{deicticSubject} {linkingVerb} where {abstractSubject} {startVerb}.",
    "{deicticSubject} {linkingVerb} the reason {abstractSubject} {importanceVerb}."
  ],
  "slots": {
    "deicticSubject": ["that", "this", "it"],
    "linkingVerb": ["is", "was"],
    "evaluativeAdjective": [
      "real",
      "strange",
      "deeper",
      "hard",
      "quiet",
      "simple",
      "honest",
      "actual",
      "central",
      "boring",
      "useful",
      "missing",
      "whole",
      "right",
      "wrong"
    ],
    "summaryNoun": [
      "part",
      "promise",
      "truth",
      "lesson",
      "point",
      "reward",
      "nature",
      "invitation",
      "shift",
      "work",
      "report",
      "decision",
      "decisions",
      "fix",
      "problem",
      "question",
      "audit question",
      "strategy",
      "plan",
      "surface",
      "layer",
      "source material",
      "issue",
      "signal",
      "reason",
      "takeaway"
    ],
    "summaryVerb": ["changes", "changed", "shifts", "shifted"],
    "changeVerb": ["changes", "changed", "reshapes", "reframes"],
    "changeObject": [
      "brief",
      "page brief",
      "report",
      "plan",
      "strategy",
      "conversation",
      "decision"
    ],
    "abstractSituation": [
      "world",
      "world we are in",
      "moment",
      "reality",
      "new reality",
      "search reality",
      "context"
    ],
    "meaningVerb": ["means", "meant", "does not mean", "doesn't mean"],
    "explanationVerb": ["shows", "showed", "explains", "explained", "proves"],
    "weakJudgment": [
      "useless",
      "useful",
      "simple",
      "enough",
      "wrong",
      "right",
      "dead",
      "alive"
    ],
    "artifactNoun": [
      "article",
      "content",
      "draft",
      "page",
      "post",
      "report",
      "source"
    ],
    "thinObligation": [
      "be useful",
      "stand alone",
      "carry the answer",
      "contain the signal",
      "contain the useful part"
    ],
    "abstractObject": [
      "source material",
      "evidence",
      "detail",
      "context",
      "substance",
      "signal"
    ],
    "abstractGerund": ["retrieving", "citing", "sharing", "remembering"],
    "genericAudience": [
      "nobody",
      "people",
      "fans",
      "everyone",
      "most people",
      "teams",
      "leaders"
    ],
    "reactionVerb": [
      "wants to hear",
      "love",
      "loves",
      "miss",
      "misses",
      "forget",
      "forgets",
      "avoid",
      "avoids"
    ],
    "thinPredicate": [
      "matters",
      "changes everything",
      "makes the difference",
      "survives",
      "does the work"
    ],
    "abstractSubject": [
      "progress",
      "trust",
      "clarity",
      "content",
      "engagement",
      "source material",
      "the work",
      "the shift",
      "the lesson",
      "the story",
      "the answer",
      "the focus",
      "the strategy",
      "the plan",
      "the problem",
      "the solution",
      "the report",
      "the decision",
      "everything"
    ],
    "abstractVerb": [
      "lives",
      "starts",
      "begins",
      "happens",
      "changes",
      "settles",
      "works",
      "matters",
      "moves"
    ],
    "importanceVerb": ["matters", "works", "changes", "counts", "sticks"],
    "startVerb": [
      "starts",
      "begins",
      "begins to feel different",
      "happens",
      "shows up",
      "takes root"
    ]
  },
  "rejectIf": [
    "sentence names the concrete lesson, truth, or decision",
    "sentence is a literal pointer to a visible object",
    "sentence includes a concrete result with a named actor and action"
  ],
  "positiveExamples": [
    "That is the real promise.",
    "That is the lesson, and it applies more widely than people think.",
    "This is the part fans love.",
    "That is where progress lives.",
    "That is how real progress usually looks.",
    "It is the simple truth."
  ],
  "negativeExamples": [
    "This is the screw that holds the hinge plate in place.",
    "That is the lesson: replace the expired signing key before Friday.",
    "It was the part Marius ordered from the blacksmith.",
    "This is where Cassia found the brass gear under the wagon wheel."
  ],
  "notes": [
    "This pattern is intentionally contains-mode because generated prose embeds this frame inside longer sentences.",
    "It overlaps with generic-signposting but targets deictic summary language specifically."
  ]
}
